      "build-debug"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "never",
  },
  {
    "label": "Configure Platformer Release",
    "command": "cmake",
