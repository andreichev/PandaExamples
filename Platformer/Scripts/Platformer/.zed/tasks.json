[
  {
    "label": "Configure Platformer Debug",
    "command": "cmake",
    "args": [
      "--preset",
      "debug"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "never",
  },
