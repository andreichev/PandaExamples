      "--preset",
      "release"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "never",
  },
  {
    "label": "Build Platformer Release",
    "command": "cmake",
    "args": [
      "--build",
